<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
    </style>


    <!--
        Splash theme.
          * Android 12+ uses the SplashScreen API (windowSplash*
            attrs): solid color bg + centered ic_launcher_foreground.
          * Android 11 and below fall back to android:background.
        Both paths point at @color/splashBackground so the splash is
        the same black on every supported Android version. Until
        @capacitor/assets is run with a custom resources/icon.png the
        foreground is the default Capacitor launcher; it will be
        replaced automatically once an icon is supplied.
    -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:windowSplashScreenBackground">@color/splashBackground</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
        <item name="android:background">@color/splashBackground</item>
    </style>
</resources>