# yt-worker environment example.
# Copy this to .env (or set in your process manager) and replace values.
# This file is committed; .env / .env.* are NOT.

# Local dev
PORT=3001
WORKER_API_SECRET=replace-me-with-a-long-random-string
ALLOWED_ORIGIN=http://localhost:3000

# Public URL of the worker, used to build absolute download links
# returned to the frontend. Set this in production so the frontend gets
# https:// download links even if your nginx vhost forgets to forward
# X-Forwarded-Proto. Leave blank in dev.
# WORKER_PUBLIC_URL=https://worker.pepinho.lol

# Optional binary overrides
# YT_DLP_BINARY=/usr/local/bin/yt-dlp
# FFMPEG_BINARY=/usr/local/bin/ffmpeg

# Optional anti-bot tuning for YouTube downloads from cloud IPs.
# Comma-separated yt-dlp player clients to try, in order.
# Default is "web_safari,tv,mweb,ios" (all cookie-aware).
# YT_DLP_PLAYER_CLIENTS=web_safari,tv,mweb,ios
# Path to a Netscape-format cookies file exported from a logged-in browser.
# Cookies decay (Google rotates sessions used from datacenter IPs), so
# expect to re-export periodically unless you also set YT_DLP_PROXY.
# YT_DLP_COOKIES=/etc/yt-worker-cookies.txt
# yt-dlp remote-components flag for the embedded JS challenge solver.
# Defaults to "ejs:github". Set to empty to disable remote downloads.
# YT_DLP_REMOTE_COMPONENTS=ejs:github
# Outbound proxy for yt-dlp. The most reliable long-term fix for YouTube's
# anti-datacenter checks is routing requests through a residential IP.
# Once set, cookies become effectively optional for the vast majority of
# content. Format: http(s)://user:pass@host:port or socks5://user:pass@host:port
# YT_DLP_PROXY=http://user:pass@residential-proxy.example.com:8000

# --- Production (DigitalOcean) example ---
# PORT=3001
# WORKER_API_SECRET=<long-random-string-shared-with-vercel-frontend>
# ALLOWED_ORIGIN=https://pepinho.lol
