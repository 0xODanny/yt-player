# Frontend env example. Copy to .env.local (gitignored) and customize.
# Both vars must be public (NEXT_PUBLIC_*) because they are read in the browser.

# Local dev (point at the worker running locally on :3001)
NEXT_PUBLIC_WORKER_API_URL=http://localhost:3001
NEXT_PUBLIC_WORKER_API_KEY=replace-me-with-the-same-string-as-WORKER_API_SECRET

# --- Production (Vercel) ---
# Set these in the Vercel project settings, NOT in this file.
# NEXT_PUBLIC_WORKER_API_URL=https://worker.pepinho.lol
# NEXT_PUBLIC_WORKER_API_KEY=<same-string-as-WORKER_API_SECRET-on-DigitalOcean>

# Leaving NEXT_PUBLIC_WORKER_API_URL blank falls back to the in-Next.js fake job
# routes (/api/jobs, /api/jobs/[id]) which do not actually download anything.
