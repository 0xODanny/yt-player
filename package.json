{
  "name": "yt-local-tool",
  "version": "1.1.19",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "build:capacitor": "node scripts/build-capacitor.mjs",
    "cap:sync": "node scripts/build-capacitor.mjs --sync-only",
    "cap:open:android": "cap open android",
    "build:android:release": "node scripts/build-capacitor.mjs && (cd android && ./gradlew assembleRelease)",
    "refresh:cookies": "./scripts/refresh-yt-cookies.sh",
    "assets:generate": "capacitor-assets generate --android --iconBackgroundColor '#c2d884' --splashBackgroundColor '#c2d884' --iconBackgroundColorDark '#c2d884' --splashBackgroundColorDark '#c2d884' && node scripts/build-pwa-icons.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.1.2",
    "@capacitor/filesystem": "^6.0.1",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/share": "^6.0.2",
    "@jofr/capacitor-media-session": "^4.0.0",
    "next": "15.5.18",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.1.2",
    "@types/node": "20.17.57",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "typescript": "5.8.3"
  }
}
